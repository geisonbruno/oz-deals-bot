# Amazon PA-API credentials
# Get these from your Amazon Associates / PA-API dashboard
AMAZON_ACCESS_KEY=your_access_key_here
AMAZON_SECRET_KEY=your_secret_key_here
AMAZON_PARTNER_TAG=your-tag-22

# Telegram
# Create a bot via @BotFather and add it as admin to your channel
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHANNEL_ID=@your_channel_id

# PostgreSQL
# Used by both the application and docker-compose.yml
DB_USERNAME=postgres
DB_PASSWORD=postgres
